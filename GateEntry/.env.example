# ─── Website Connection ─────────────────────────────────
WEBSITE_URL=http://localhost:3000
GATE_API_KEY=change-this-to-a-secure-random-key

# ─── Database Path (external drive recommended) ─────────
# Mount your external drive and set the path here.
# Example: /mnt/usb/gateentry/gate.db
DB_PATH=/mnt/usb/gateentry/gate.db

# ─── Device Identity ────────────────────────────────────
DEVICE_ID=gate-pi-001

# ─── Hardware Pins (BCM numbering) ──────────────────────
# GPIO pin connected to relay module that controls magnetic lock
RELAY_PIN=17
# GPIO pin for status LED (green = ready, blink = access granted)
LED_GREEN_PIN=27
# GPIO pin for denied LED (red blink = denied)
LED_RED_PIN=22
# GPIO pin for buzzer (optional, short beep on scan)
BUZZER_PIN=23

# ─── Timing (milliseconds) ─────────────────────────────
# How long to hold the gate open after valid scan
GATE_OPEN_DURATION_MS=5000
# How often to sync with the website (ms) — default 1 hour
SYNC_INTERVAL_MS=3600000

# ─── RFID Reader ────────────────────────────────────────
# SPI bus and device for MFRC522 reader
SPI_BUS=0
SPI_DEVICE=0

# ─── Read-only Viewer UI ─────────────────────────────────
# Viewer runs on Pi to inspect local DB (no edits)
VIEWER_HOST=0.0.0.0
VIEWER_PORT=8080

# ─── Phone Access (iPhone + Android) ─────────────────────
# Optional pre-shared key required by the /api/gate/phone-unlock
# endpoint. Companion apps must send it as header X-Gate-Phone-Key
# or as gate_key in the JSON body. Leave blank to disable the check
# (useful for isolated pool Wi-Fi networks).
PHONE_UNLOCK_KEY=
