# ─── Server ───────────────────────────────────────────────
PORT=3000
SITE_URL=http://localhost:3000         # Production: https://yourdomain.com
SESSION_SECRET=replace-with-a-long-random-string

# ─── Branding (shown in emails / page footers) ─────────────
BRAND_NAME=Glenridge Community HOA
BRAND_SHORT=Glenridge Community
BRAND_LOCATION=Winston-Salem, NC
MAIL_FROM_EMAIL=                       # Optional. Defaults to SMTP_USER if blank.

# ─── Admin credentials ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_EMAIL=admin@glenridgecommunity.com

# ─── Gate Controller (Raspberry Pi) ─────────────────────
GATE_API_KEY=change-this-to-a-secure-random-key
GATE_VIEWER_URL=http://localhost:8080
# Shared key used both for admin proxy calls and the mobile-app gate-open
# relay. Must match PHONE_UNLOCK_KEY in GateEntry/.env on the Pi.
GATE_VIEWER_KEY=

# ─── Pool Geofence (mobile-app gate open) ──────────────
# Set to the latitude/longitude of the pool gate. The mobile app gate-open
# endpoint will reject requests from devices farther than POOL_GEOFENCE_METERS.
# Leave blank to disable server-side geofence verification.
POOL_LATITUDE=
POOL_LONGITUDE=
POOL_GEOFENCE_METERS=250

# ─── MySQL Database ────────────────────────────────────────
# Hostinger: find these in hPanel → Hosting → Databases → MySQL
# Hostinger DB names/users are prefixed with your account ID, e.g. u123456789_glenridge
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# ─── SMTP (email notifications) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-gmail-app-password   # Gmail App Password (NOT your regular password)

# ─── Twilio (SMS broadcasts) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555551234

# ─── Google OAuth ──────────────────────────────────────────
# 1. Go to https://console.developers.google.com/
# 2. Create a project → Credentials → OAuth 2.0 Client IDs
# 3. Authorized redirect URI: http://localhost:3000/api/auth/google/callback
#    (for production: https://yourdomain.com/api/auth/google/callback)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Facebook OAuth ────────────────────────────────────────
# 1. Go to https://developers.facebook.com/apps/
# 2. Create an app → Add "Facebook Login" product
# 3. Valid OAuth Redirect URI: http://localhost:3000/api/auth/facebook/callback
#    (for production: https://yourdomain.com/api/auth/facebook/callback)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
